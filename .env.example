# ReviewForge environment variables
# Step-by-step GitHub + local run: docs/CONFIGURATION.md

# --- Database ---
# Connection string for PostgreSQL (used by Drizzle + the app)
DATABASE_URL=postgresql://reviewforge:reviewforge@localhost:5432/reviewforge

# --- Session (nuxt-auth-utils) ---
# At least 32 characters. Required in production.
NUXT_SESSION_PASSWORD=replace-with-at-least-32-random-characters

# --- GitHub OAuth (user sign-in) ---
# Must be YOUR GITHUB APP's Client ID + Client secret (see docs/CONFIGURATION.md).
# Do not use a standalone "OAuth App" — Sync from GitHub needs a GitHub App–authorized token.
# Callback URL on the GitHub App must be {BASE_URL}/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
# Optional override if the app cannot infer the public URL:
# NUXT_OAUTH_GITHUB_REDIRECT_URL=http://localhost:3000/auth/github

# --- Public app URL ---
# Used for redirects and documentation links in the UI
NUXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Same GitHub App (App ID + key + webhooks + install slug) ---
NUXT_GITHUB_APP_ID=
# PEM contents: use literal newlines, or base64 without BEGIN/END headers
NUXT_GITHUB_APP_PRIVATE_KEY=
NUXT_GITHUB_WEBHOOK_SECRET=
# Slug from https://github.com/apps/<slug>
NUXT_PUBLIC_GITHUB_APP_SLUG=

# --- Per-user Cursor API keys (AI PR reviews) ---
# At least 32 characters. Encrypts each user's Cursor API key in the database.
# Rotating this value invalidates all stored keys until users re-enter them.
NUXT_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
# Optional: override GitHub hosted MCP URL (default: https://api.githubcopilot.com/mcp/)
# NUXT_GITHUB_MCP_REMOTE_URL=https://api.githubcopilot.com/mcp/

# --- Alternate env names (also supported by nuxt.config) ---
# DATABASE_URL is read as fallback for NUXT_DATABASE_URL
# GITHUB_APP_ID / GITHUB_APP_PRIVATE_KEY / GITHUB_WEBHOOK_SECRET / GITHUB_APP_SLUG / PUBLIC_BASE_URL
# GITHUB_MCP_REMOTE_URL / ENCRYPTION_KEY
